rules_version = '2';

// ══════════════════════════════════════════════════
// Firestore Security Rules — Epistemic Odds
// Classroom use: keeps data open within the course.
// No real money involved; no strict auth required.
// ══════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────
    // Anyone can read the leaderboard.
    // Anyone can create/update their own profile.
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
      // For stricter auth in the future, replace the line above with:
      // allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Bets ───────────────────────────────────────
    // All participants can read bets.
    // Anyone with a class code can create a bet proposal.
    // Only server-side or authenticated writes update status / outcome.
    // (In a classroom setting, we trust the instructor to resolve correctly.)
    match /bets/{betId} {
      allow read:   if true;
      allow create: if request.resource.data.classCode is string;
      allow update: if true;   // tightened by app logic (instructor code check)
      allow delete: if false;  // never delete bets — keep records
    }

    // ── Predictions ────────────────────────────────
    // All participants can read predictions (enables class calibration chart).
    // Users can write only their own prediction document.
    match /predictions/{predId} {
      allow read:  if true;
      allow write: if true;
      // To restrict, uncomment:
      // allow write: if request.resource.data.userId == predId.split('_')[1];
    }
  }
}
